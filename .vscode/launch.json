{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "MockEventApplication",
      "request": "launch",
      "mainClass": "com.govtech.mock.MockEventApplication",
      "projectName": "mock-event-pub-sub"
    },
    {
      "name": "Java Debug",
      "type": "java",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005
    },
    {
      "name": "Next.js Debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
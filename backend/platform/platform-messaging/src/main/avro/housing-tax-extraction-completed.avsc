          { "name": "taxpayerLastName", "type": ["null","string"], "default": null },
          { "name": "taxYear", "type": ["null","int"], "default": null },
          { "name": "street", "type": ["null","string"], "default": null },
          { "name": "postalCode", "type": ["null","string"], "default": null },
          { "name": "city", "type": ["null","string"], "default": null },
          { "name": "taxAmount", "type": ["null","double"], "default": null }
        ]
      }
    }
  ]
}
{
  "type": "record",
  "name": "HousingTaxExtractionCompletedEvent",
  "namespace": "com.govtech.events.housingtax",
  "fields": [
    {
      "name": "metadata",
      "type": "com.govtech.events.common.DocumentBaseEvent"
    },
    {
      "name": "extractedData",
      "type": {
        "type": "record",
        "name": "HousingTaxExtractedData",
        "fields": [
